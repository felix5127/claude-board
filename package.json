{
  "name": "claude-board",
  "version": "0.1.0",
  "description": "Visual dashboard for Claude Code conversations — view chat history, tool usage, token analytics, and agent teams",
  "main": "dist/server/index.js",
  "bin": {
    "claude-board": "./dist/server/cli.js"
  },
  "files": [
    "dist/client/index.html",
    "dist/client/assets/",
    "dist/server/**/*.js",
    "!dist/server/**/__tests__/"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "prepublishOnly": "npm run test:run && npm run build",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": ["claude", "claude-code", "dashboard", "visualizer", "conversation", "analytics", "cli"],
  "author": "Felix <512780808@qq.com> (https://github.com/felix5127)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/felix5127/claude-board.git"
  },
  "homepage": "https://github.com/felix5127/claude-board#readme",
  "bugs": {
    "url": "https://github.com/felix5127/claude-board/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "dependencies": {
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-window": "^2.2.7",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
